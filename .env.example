# Required
POSTGRES_URL=

# Hugging Face token for embeddings/LLM (https://huggingface.co/settings/tokens)
HUGGING_FACE_API_KEY=

# Optional: OpenAI-compatible key/base URL (OpenAI, Together, AI Gateway, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Defaults to Meta Llama 3.1 8B instruct when using Hugging Face
AI_MODEL=meta-llama/Llama-3.1-8B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
