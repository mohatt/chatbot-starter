# Required for vector database
POSTGRES_URL=

# Hugging Face token for embeddings/LLM (https://huggingface.co/settings/tokens)
# If not specified, Vercel AI Gateway will be used
HUGGING_FACE_API_KEY=

# Defaults to:
# - meta-llama/Llama-3.1-8B-Instruct when using Hugging Face
# - openai/gpt-4o-mini when using AI Gateway
AI_MODEL=

# Defaults to openai/text-embedding-3-small
EMBEDDING_MODEL=
