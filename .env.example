# Required for relational database
POSTGRES_URL=

# Required for BetterAuth
# You can use `openssl rand -base64 32` to generate one
BETTER_AUTH_SECRET=
# Base URL of your app
BETTER_AUTH_URL=http://localhost:3000

# Required for vector database
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Required for vercel blob storage
BLOB_READ_WRITE_TOKEN=
BLOB_BASE_URL=

# Required for Cron jobs security
# You can use `openssl rand -base64 32` to generate one
CRON_SECRET=

# Vercel auth token for AI Gateway and vercel blob
VERCEL_OIDC_TOKEN=

# Optional Hugging Face token (https://huggingface.co/settings/tokens)
HUGGING_FACE_API_KEY=
